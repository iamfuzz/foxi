# EC2-specific kernel configuration fragment.
# Applied on top of Alpine's config via scripts/kconfig/merge_config.sh.
# Reference: https://docs.aws.amazon.com/AWSEC2/latest/UserGuide/instance-types.html

# ── Hypervisor support ────────────────────────────────────────────────────────
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y

# Xen (c4/m4/r4 and older instance families use Xen)
CONFIG_XEN=y
CONFIG_XEN_BLKDEV_FRONTEND=y
CONFIG_XEN_NETDEV_FRONTEND=y
CONFIG_XEN_PCIDEV_FRONTEND=y

# KVM / Nitro hypervisor (C5/M5/R5 and newer)
CONFIG_KVM_GUEST=y

# ── Networking ────────────────────────────────────────────────────────────────
# ENA: required on all Nitro-based instances (C5/M5/R5/G4+ and Graviton)
CONFIG_ENA_ETHERNET=y
# Virtio NIC (useful for t2/t3 and local QEMU testing)
CONFIG_VIRTIO_NET=y

# ── Storage ───────────────────────────────────────────────────────────────────
# NVMe: instance store and EBS on Nitro instances
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_MULTIPATH=y
# Virtio block (EBS on Xen instances, QEMU testing)
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_SCSI=y
# SCSI disk (required for virtio-scsi)
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI=y

# ── Virtio bus ────────────────────────────────────────────────────────────────
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_INPUT=y

# ── Console / serial ──────────────────────────────────────────────────────────
# EC2 serial console (available on Nitro; also used for early boot messages)
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_PCI=y
CONFIG_TTY=y
CONFIG_VT=y

# ── Boot / EFI ────────────────────────────────────────────────────────────────
# EC2 supports UEFI boot on Nitro instances
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_VARS=y
CONFIG_FB_EFI=y
CONFIG_FRAMEBUFFER_CONSOLE=y

# ── Filesystems ───────────────────────────────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
# vfat for EFI partition
CONFIG_FAT_FS=y
CONFIG_VFAT_FS=y

# ── Namespaces / cgroups (cloud-init, containers) ────────────────────────────
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_BPF=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CPUSETS=y

# ── IMDSv2 / network ─────────────────────────────────────────────────────────
CONFIG_INOTIFY_USER=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y

# ── Random / entropy ─────────────────────────────────────────────────────────
# Virtio RNG (provides fast entropy on EC2)
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# ── IMDSv2 enforcement (security) ────────────────────────────────────────────
# Ensure instances can enforce IMDSv2-only at launch; no kernel config needed,
# but the image must ship with a cloud-init config that disables IMDSv1.
